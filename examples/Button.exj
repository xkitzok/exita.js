Add.Module [Button.hxj]

function Button({ variant = "primary", size = "md", children, onClick }) {
  return (
    <button 
      class={`btn-${variant}`}
      onClick={onClick}
      style={{ padding: '8px 16px', margin: '4px', cursor: 'pointer' }}
    >
      {children}
    </button>
  )
}

export { Button }
